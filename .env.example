# PlantCart SaaS environment — copy to .env and fill in.
# Every value here is read in server/config.py.

# --- server ---
PLANTCART_ENV=production                 # "production" hard-fails if PLANTCART_SECRET is unset
PLANTCART_HOST=0.0.0.0                    # bind address (leave as-is in a container)
PLANTCART_PORT=8123                       # listen port (matches the image EXPOSE)
PLANTCART_DB=/data/plantcart.db          # SQLite path — MUST be on a persistent volume

# --- auth ---
# REQUIRED in production. Generate a strong one:
#   python -c "import secrets;print(secrets.token_urlsafe(48))"
PLANTCART_SECRET=                         # JWT signing secret — set this, never commit it
PLANTCART_TOKEN_TTL_DAYS=30               # auth token lifetime in days

# CORS: comma-separated origins, or "*". Pin to your web origin in production.
PLANTCART_CORS=https://plantcart.example.com

# --- LLM provider: anthropic | openai_compatible | none ---
PLANTCART_LLM_PROVIDER=anthropic          # "none" disables LLM features
ANTHROPIC_API_KEY=                        # required when provider=anthropic
PLANTCART_LLM_MODEL=claude-haiku-4-5-20251001   # model id for enrichment/recipes

# openai_compatible provider (e.g. self-hosted vLLM) — only used when provider=openai_compatible
PLANTCART_OPENAI_BASE_URL=http://127.0.0.1:8000/v1
PLANTCART_OPENAI_MODEL=Intel/Qwen3.5-122B-A10B-int4-AutoRound

# --- optional: SearXNG for new-item typo verification (empty = disabled) ---
PLANTCART_SEARX_URL=
