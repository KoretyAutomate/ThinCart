# ThinCart SaaS environment — copy to .env and fill in.
# Every value here is read in server/config.py.

# --- server ---
THINCART_ENV=production                 # "production" hard-fails if THINCART_SECRET is unset
THINCART_HOST=0.0.0.0                    # bind address (leave as-is in a container)
THINCART_PORT=8123                       # listen port (matches the image EXPOSE)
THINCART_DB=/data/thincart.db          # SQLite path — MUST be on a persistent volume

# --- auth ---
# REQUIRED in production. Generate a strong one:
#   python -c "import secrets;print(secrets.token_urlsafe(48))"
THINCART_SECRET=                         # JWT signing secret — set this, never commit it
THINCART_TOKEN_TTL_DAYS=30               # auth token lifetime in days

# CORS: comma-separated origins, or "*". Pin to your web origin in production.
THINCART_CORS=https://thincart.example.com

# --- LLM provider: anthropic | openai_compatible | none ---
THINCART_LLM_PROVIDER=anthropic          # "none" disables LLM features
ANTHROPIC_API_KEY=                        # required when provider=anthropic
THINCART_LLM_MODEL=claude-haiku-4-5-20251001   # model id for enrichment/recipes

# openai_compatible provider (e.g. self-hosted vLLM) — only used when provider=openai_compatible
THINCART_OPENAI_BASE_URL=http://127.0.0.1:8000/v1
THINCART_OPENAI_MODEL=Intel/Qwen3.5-122B-A10B-int4-AutoRound

# --- optional: SearXNG for new-item typo verification (empty = disabled) ---
THINCART_SEARX_URL=
